# ─────────────────────────────────────────────────────────────────────────────
# Casio proprietary firmware — NEVER commit.
# The fx-CG50 OS images / flash dumps are Casio's copyrighted property. You must
# supply your own dump of your own calculator (see README and tools/flash_dump/).
# The whole os/ tree (physical flash dump, the 3.80 updater, and everything
# extracted/decoded from them) is excluded.
# ─────────────────────────────────────────────────────────────────────────────
/os/

# State/memory snapshots and boot goldens that are *derived from executing* the
# Casio OS (they contain OS bytes / OS-execution results).
emu/*.pkl
emu/golden_boot.bin
emu_go/fb_raw.bin

# Screenshots / framebuffer renders of the copyrighted on-screen UI.
*.png
*.bmp

# Personal tooling tied to a private endpoint — not part of the emulator.
tools/push_note.py

# Build artifacts
*.exe

# Python / editor cruft
__pycache__/
*.pyc

# Local Claude Code harness config (machine-specific permissions/paths)
.claude/
